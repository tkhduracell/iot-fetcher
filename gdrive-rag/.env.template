# Google service account JSON (same format as fetcher-core's GOOGLE_SERVICE_ACCOUNT)
GOOGLE_SERVICE_ACCOUNT='{"type":"service_account",...}'

# Gemini API key (for embeddings + Flash extraction)
GEMINI_API_KEY=

# Comma-separated Drive folder IDs to index (whitelist)
RAG_ROOT_FOLDER_IDS=

# Model selection (swap without rebuild)
RAG_EMBED_MODEL=gemini-embedding-001
RAG_EXTRACT_MODEL=gemini-2.5-flash-lite

# Core tuning
RAG_SYNC_INTERVAL=10m
RAG_CHUNK_TOKENS=800
RAG_CHUNK_OVERLAP=100
# 25 chunks * 800 tokens = 20K, matching gemini-embedding-001's per-request cap
RAG_EMBED_BATCH_SIZE=25
RAG_LISTEN_ADDR=:8090
RAG_DATA_DIR=/data
RAG_LOG_LEVEL=info

# Free-tier guardrails — set below the advertised free-tier limits so transient
# bursts never trip 429s. Numbers sized from April 2026 free-tier quotas:
#   gemini-2.5-flash-lite: 15 RPM, 250K TPM, 1000 RPD
#   gemini-embedding-001 : TPM-gated at 250K TPM per project (no hard RPD)
# Raise after observing real consumption on /status.
RAG_EMBED_TPM_CAP=200000      # tokens/min to gemini-embedding-001 (below 250K)
RAG_EMBED_RPM_CAP=10          # requests/min, soft secondary cap
RAG_FLASH_RPM_CAP=10          # below 15 RPM
RAG_FLASH_DAILY_REQUEST_CAP=800  # below 1000 RPD

# File-size / shape cutoffs — skip or truncate files that would blow the budget.
# Skipped files are logged and recorded in state so the user can raise caps
# and re-run on them selectively.
RAG_MAX_FILE_SIZE_MB=50
RAG_MAX_PDF_PAGES=500                        # hard ceiling; skip beyond this
RAG_PDF_MAX_PAGES_PER_CALL=20                # chunk size for Flash-Lite OCR
RAG_PDF_TEXT_LAYER_MIN_CHARS_PER_PAGE=100    # below this → treat as scanned
RAG_SKIP_IMAGE_EXTRACTION=false              # flip to `true` to never OCR images
