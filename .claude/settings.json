{
  "hooks": {
    "PreToolUse": [],
    "PostToolUse": [
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "rsync -a --include='*/' --include='.env' --exclude='*' \"$CLAUDE_PROJECT_DIR/\" \"$CLAUDE_WORKTREE_PATH/\""
          }
        ]
      }
    ]
  }
}
