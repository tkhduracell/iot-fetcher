# Gemini API
GEMINI_API_KEY=your-gemini-api-key

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://ai.filiplindqvist.com

# Comma-separated list of allowed email addresses (empty = allow all)
ALLOWED_EMAILS=filip@example.com

# Home automation backends
# Sonos runs on host network, so use host.docker.internal from containers
SONOS_HOST=host.docker.internal
ROBOROCK_SIDECAR_URL=http://iot-fetcher:8081
INFLUXDB_V3_URL=
INFLUXDB_V3_ACCESS_TOKEN=

# Brave Search API
BRAVE_API_KEY=

# Google Sheets service account (JSON key, single line)
GOOGLE_SHEETS_SERVICE_ACCOUNT_KEY=

# SQLite database path (default: ./data/chat.db)
# SQLITE_PATH=/app/data/chat.db
