# sigenergy-bridge — local config template
# Copy to .env (or merge into the shared fetcher-core .env) and fill in the
# blanks. Required vars fail-fast at startup; optional vars show their
# defaults.

# --- Sigenergy inverter (Modbus TCP) ---------------------------------
# RFC1918 private IP only; startup refuses anything else.
SIGENERGY_HOST=
SIGENERGY_PORT=502
# "Unlimited" discharge ceiling written on unclamp, in watts.
# Leave empty (or 0) to auto-detect from the plant nameplate (register
# 30010) and apply SIGENERGY_DISCHARGE_MARGIN_PCT. Only set an explicit
# value if the nameplate read is unreliable on your hardware or you want
# a hard ceiling below the nameplate.
SIGENERGY_DISCHARGE_UNLIMITED_W=
# Percentage shaved off the auto-detected nameplate to give the inverter
# a safety margin on the restore value. 10 → restore at 90% of nameplate.
# Ignored when SIGENERGY_DISCHARGE_UNLIMITED_W is set.
SIGENERGY_DISCHARGE_MARGIN_PCT=10

# --- Home Assistant WebSocket ---------------------------------------
# docker-compose.yml runs this service with network_mode: host, so the
# HA container on the same rpi5 is reachable at ws://localhost:8123.
HA_URL=ws://localhost:8123/api/websocket
# Long-lived access token — profile → Security → "Create token".
HA_TOKEN=

# --- Wallbox state source --------------------------------------------
# HA entity whose state transitions drive the clamp. For Wallbox Pulsar /
# Pulsar MAX / Quasar via the myWallbox integration this is the
# battery_charging binary_sensor (raw state "on" / "off"). Find the exact
# entity_id under Developer Tools → States → filter by friendly name
# "<your wallbox> Charging". Examples:
#   binary_sensor.pulsar_max_sn_992144_charging
#   binary_sensor.wallbox_charging
WALLBOX_HA_ENTITY=
# Comma-separated list of raw entity states that mean "the car is drawing
# energy right now". Anything else → idle. Case-sensitive. For a
# battery_charging binary_sensor the raw state is "on" / "off" (NOT the
# translated "Charging" / "Not charging" that HA renders in the UI).
WALLBOX_CHARGING_STATES=on

# --- VictoriaMetrics / InfluxDB v3 Cloud -----------------------------
# Shared with the Python fetcher; typically already set in the parent .env.
INFLUX_HOST=
INFLUX_TOKEN=
INFLUX_DATABASE=

# --- Tuning knobs ----------------------------------------------------
# Modbus poll cadence for VM metrics. Matches the retired Python module.
POLL_INTERVAL=60s
# If the HA WebSocket is unreachable for longer than this while clamped,
# release the clamp as a failsafe — better to over-discharge than to
# strand the battery in the dark.
HA_FAILSAFE_TIMEOUT=120s
# Absolute upper bound on any single clamp, regardless of Wallbox state.
# Guards against a stuck Wallbox entity holding the battery forever.
# Set to 0 to disable (debugging only).
MAX_CLAMP_DURATION=4h

# --- Operational toggles --------------------------------------------
# When true, Modbus writes are logged instead of sent. Safe starting mode
# for the first few deploys while the register map is being validated on
# live hardware.
DRY_RUN=false
# slog level: DEBUG | INFO | WARN | ERROR.
LOG_LEVEL=INFO
